<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:GraphVisualizer"
        x:Class="GraphVisualizer.MainWindow"
        Width="1000" Height="800"
        Title="Dijkstra Visualizer">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10" Spacing="10">

    <TextBlock Text="Vertices:" VerticalAlignment="Center"/>
    <TextBox x:Name="VertexCountBox" Width="60" Text="45"/>

    <TextBlock Text="Neighbors:" VerticalAlignment="Center"/>
    <TextBox x:Name="NeighborCountBox" Width="60" Text="2"/>

    <Button Content="Generate Graph" Click="GenerateGraph_Click"/>
    <Button Content="Clear Walls" Click="ClearWalls_Click"/>

    <TextBlock x:Name="InfoText" Text="Left click = target, Right click = wall" VerticalAlignment="Center"/>

</StackPanel>

        <local:GraphCanvas x:Name="MyGraphCanvas"/>
    </DockPanel>
</Window>